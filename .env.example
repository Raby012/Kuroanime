# Database (PostgreSQL via Supabase - free tier)
# Get from: https://supabase.com → Project → Settings → Database
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Auth.js secret (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-here"

# Google OAuth
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
# Get from: https://github.com → Settings → Developer settings → OAuth Apps
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Your site URL (for auth callbacks)
NEXTAUTH_URL="http://localhost:3000"

# TMDB (optional - for better episode/season data)
# Get from: https://www.themoviedb.org/settings/api
NEXT_PUBLIC_TMDB_API_KEY="your-tmdb-key"
